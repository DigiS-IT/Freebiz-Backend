# ============================================
# FREEBIZ BACKEND - ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/freebiz_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# SMS/OTP Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
OTP_EXPIRY_MINUTES=5

# Google Maps Configuration
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/mov,video/avi

# QR Code Configuration
QR_CODE_SECRET=your-qr-code-secret-for-validation
QR_CODE_LOGO_PATH=./assets/freebiz-logo.png

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Logging
LOG_LEVEL=debug
